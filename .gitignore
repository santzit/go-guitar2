# Godot 4+ — commit extension_list.cfg and imported/ so a fresh clone works
# without running "godot --import" first.  Without imported/ the font preload
# in chord.gd fails at parse time and all texture/mesh assets are unavailable.
# Exclude only machine-local editor caches that should never be committed.
.godot/editor/
.godot/global_script_class_cache.cfg
.godot/scene_groups_cache.cfg
.godot/uid_cache.bin
.godot/.gdignore
.nomedia
*.uid

# Godot-specific ignores
.import/
export.cfg
export_credentials.cfg

# Imported translations (automatically generated from CSV files)
*.translation

# Mono-specific ignores
.mono/
data_*/
mono_crash.*.json

# Rust build artefacts (keep gdextension/bin/ tracked — pre-built binaries)
gdextension/target/
wget-log

# Godot binary (downloaded at runtime, not committed)
Godot_v4.4.1-stable_linux.x86_64
Godot_v4.4.1-stable_linux.x86_64.zip
g.zip

# Dataset WAV files — large binary assets populated locally via:
# git clone https://github.com/santzit/guitar-pitch-detection- /tmp/gpd
# cp -r /tmp/gpd/tests/dataset/* tests/note-detection/dataset/
tests/note-detection/dataset/**/*.wav
tests/note-detection/dataset/**/*.WAV
