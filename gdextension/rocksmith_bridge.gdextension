[configuration]
entry_symbol = "gdext_rust_init"
compatibility_minimum = "4.4"

[libraries]
linux.debug.x86_64   = "res://gdextension/bin/libgodot_rocksmith.so"
linux.release.x86_64 = "res://gdextension/bin/libgodot_rocksmith.so"
windows.debug.x86_64   = "res://gdextension/bin/godot_rocksmith.dll"
windows.release.x86_64 = "res://gdextension/bin/godot_rocksmith.dll"
macos.debug   = "res://gdextension/bin/libgodot_rocksmith.dylib"
macos.release = "res://gdextension/bin/libgodot_rocksmith.dylib"

[dependencies]
linux.x86_64 = {"res://gdextension/bin/librocksmith_shim.so": ""}
