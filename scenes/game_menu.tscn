[gd_scene load_steps=2 format=3]

[ext_resource type="Script" path="res://scripts/game_menu.gd" id="1_menu_script"]

[node name="GameMenu" type="Control"]
layout_mode = 3
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
script = ExtResource("1_menu_script")

[node name="MarginContainer" type="MarginContainer" parent="."]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
offset_left = 100.0
offset_top = 80.0
offset_right = -100.0
offset_bottom = -80.0
grow_horizontal = 2
grow_vertical = 2

[node name="VBoxContainer" type="VBoxContainer" parent="MarginContainer"]
layout_mode = 2
theme_override_constants/separation = 12

[node name="Title" type="Label" parent="MarginContainer/VBoxContainer"]
layout_mode = 2
theme_override_font_sizes/font_size = 30
text = "GoGuitar2"
horizontal_alignment = 1

[node name="SongListButton" type="Button" parent="MarginContainer/VBoxContainer"]
layout_mode = 2
text = "Song list"

[connection signal="pressed" from="MarginContainer/VBoxContainer/SongListButton" to="." method="_on_song_list_button_pressed"]
