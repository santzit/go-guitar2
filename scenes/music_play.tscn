; ── Root ──────────────────────────────────────────────────────────────────────
[node name="MusicPlay" type="Node3D"]
script = ExtResource("3_script")

; ── Directional sun-light (angled from upper-right) ──────────────────────────
[node name="DirectionalLight3D" type="DirectionalLight3D" parent="."]
transform = Transform3D(0.866025, -0.433013, 0.25, 0, 0.5, 0.866025, -0.5, -0.75, 0.433013, 0, 10, 2)
light_color    = Color(0.72, 0.86, 1, 1)
light_energy   = 1.6
shadow_enabled = true

; Camera: position (12, 3, 26) beyond the strum line (Z=20), looking toward Z=10.
; camera-right = world +X  →  fret 1 (X=0.5) on LEFT, fret 24 (X=23.5) on RIGHT
; camera-up   = world +Y  →  string 0 (Y=0.20) at BOTTOM, string 5 (Y=2.70) at TOP
; No axis inversions needed anywhere. Basis computed from look_at((12,3,26)→(12,0,10), up=Y):
;   forward = normalize(0,-3,-16)  → basis.z = normalize(0,3,16) = (0, 0.1845, 0.9828)
;   basis.x = normalize(cross(forward, up)) = (1, 0, 0)
;   basis.y = cross(basis.z, basis.x)       = (0, 0.9828, -0.1845)
[node name="Camera3D" type="Camera3D" parent="."]
; Tuned to keep the highway dominant in frame and closer to ChartPlayer screenshot framing.
position = Vector3(12, 4.2, 27.5)
rotation_degrees = Vector3(-16, 0, 0)
fov = 46.0

; ── Background (sky + WorldEnvironment + bloom) ───────────────────────────────
[node name="Background" parent="." instance=ExtResource("2_bg")]
visible = false

; ── Highway (fret surface + strum line + side walls) ─────────────────────────
[node name="Highway" parent="." instance=ExtResource("1_highway")]

[node name="Fretboard" parent="." instance=ExtResource("5_fretboard")]
visible = false

; ── NotePool (128 pooled note instances) ─────────────────────────────────────
[node name="NotePool" parent="." instance=ExtResource("4_pool")]

; ── Audio playback ────────────────────────────────────────────────────────────
[node name="AudioStreamPlayer" type="AudioStreamPlayer" parent="."]
[node name="ChartPlayerReferenceHud" parent="." instance=ExtResource("6_chart_hud")]
visible = false
