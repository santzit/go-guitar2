[gd_scene load_steps=8 format=3 uid="uid://cmpscene0001"]

[ext_resource type="PackedScene" uid="uid://chighway0001" path="res://scenes/highway.tscn"     id="1_highway"]
[ext_resource type="PackedScene" uid="uid://cbkgnd00001" path="res://scenes/background.tscn"   id="2_bg"]
[ext_resource type="Script"                              path="res://scripts/music_play.gd"    id="3_script"]
[ext_resource type="PackedScene" uid="uid://cnotepool001" path="res://scenes/note_pool.tscn"   id="4_pool"]
[ext_resource type="PackedScene" path="res://scenes/fretboard.tscn" id="5_fretboard"]
[ext_resource type="PackedScene" uid="uid://cchordpool01" path="res://scenes/chord_pool.tscn"  id="6_chordpool"]
[ext_resource type="Script"                              path="res://scripts/note_timeline.gd" id="7_timeline"]

; ── Root ──────────────────────────────────────────────────────────────────────
[node name="MusicPlay" type="Node3D"]
script = ExtResource("3_script")

; ── Directional sun-light (angled from upper-right) ──────────────────────────
[node name="DirectionalLight3D" type="DirectionalLight3D" parent="."]
transform = Transform3D(0.866025, -0.433013, 0.25, 0, 0.5, 0.866025, -0.5, -0.75, 0.433013, 0, 8, 0)
light_color    = Color(0.9, 0.85, 1.0, 1)
light_energy   = 1.2
shadow_enabled = true

; Camera: position (12, 5.5, 10) — ChartPlayer-style: elevated on the player side,
; looking toward (12, 0, -7) for a natural guitar-neck perspective.
;   forward = normalize(0, -5.5, -17)  →  len=17.868
;   basis.z = -forward = (0, 0.3078, 0.9514)    (camera -Z points back = +Z world)
;   basis.x = normalize(cross(forward, up)) = (1, 0, 0)
;   basis.y = cross(basis.z, basis.x)      = (0, 0.9514, -0.3078)
[node name="Camera3D" type="Camera3D" parent="."]
transform = Transform3D(1, 0, 0, 0, 0.9514, 0.3078, 0, -0.3078, 0.9514, 12, 5.5, 10)
fov = 60.0

; ── Background (sky + WorldEnvironment + bloom) ───────────────────────────────
[node name="Background" parent="." instance=ExtResource("2_bg")]

; ── Highway (fret surface + strum line + side walls) ─────────────────────────
[node name="Highway" parent="." instance=ExtResource("1_highway")]

[node name="Fretboard" parent="." instance=ExtResource("5_fretboard")]

; ── NotePool (128 pooled note instances) ─────────────────────────────────────
[node name="NotePool" parent="." instance=ExtResource("4_pool")]

; ── ChordPool (64 pooled chord container instances) ──────────────────────────
[node name="ChordPool" parent="." instance=ExtResource("6_chordpool")]

; ── Audio playback ────────────────────────────────────────────────────────────
[node name="AudioStreamPlayer" type="AudioStreamPlayer" parent="."]
; ── Note timeline HUD (full-width bar at the top of the screen) ──────────────
[node name="TimelineOverlay" type="CanvasLayer" parent="."]
layer = 5

[node name="NoteTimeline" type="Control" parent="TimelineOverlay"]
layout_mode = 1
anchors_preset = -1
anchor_left   = 0.0
anchor_top    = 0.0
anchor_right  = 1.0
anchor_bottom = 0.0
offset_left   = 0.0
offset_top    = 0.0
offset_right  = 0.0
offset_bottom = 44.0
script = ExtResource("7_timeline")
; ── Debug info overlay (CanvasLayer so it renders on top of 3-D scene) ──────────────
[node name="DebugOverlay" type="CanvasLayer" parent="."]
layer = 10

[node name="DebugLabel" type="Label" parent="DebugOverlay"]
offset_left = 10.0
offset_top = 50.0
offset_right = 780.0
offset_bottom = 130.0
theme_override_font_sizes/font_size = 16
theme_override_colors/font_color = Color(1, 1, 0.4, 1)
theme_override_colors/font_outline_color = Color(0, 0, 0, 0.85)
theme_override_constants/outline_size = 3
text = ""
